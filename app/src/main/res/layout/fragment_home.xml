<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_buttons_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_buttons_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="1200dp">

        <!-- Self Mode Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/self_mode_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="40dp"
            android:background="@drawable/gradient_blue"
            android:elevation="6dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_launch_white"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="72dp"
            app:iconTint="#ffffff"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@+id/usb_button"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/self_mode_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_horizontal"
            android:shadowColor="@color/text_shadow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8"
            android:text="@string/self_mode"
            android:textColor="@color/text_primary"
            android:textFontWeight="700"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="@+id/self_mode_button"
            app:layout_constraintStart_toStartOf="@+id/self_mode_button"
            app:layout_constraintTop_toBottomOf="@+id/self_mode_button" />

        <!-- USB Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/usb_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="40dp"
            android:background="@drawable/gradient_orange"
            android:elevation="6dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_usb_white"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="72dp"
            app:iconTint="#ffffff"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@+id/wifi_button"
            app:layout_constraintStart_toEndOf="@+id/self_mode_button"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/usb_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_horizontal"
            android:shadowColor="@color/text_shadow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8"
            android:text="@string/usb"
            android:textColor="@color/text_primary"
            android:textFontWeight="700"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="@+id/usb_button"
            app:layout_constraintStart_toStartOf="@+id/usb_button"
            app:layout_constraintTop_toBottomOf="@+id/usb_button" />

        <!-- WiFi Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/wifi_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="40dp"
            android:background="@drawable/gradient_purple"
            android:elevation="6dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_network_wifi_white"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="72dp"
            app:iconTint="#ffffff"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@+id/settings_button"
            app:layout_constraintStart_toEndOf="@+id/usb_button"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/wifi_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_horizontal"
            android:shadowColor="@color/text_shadow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8"
            android:text="@string/wifi"
            android:textColor="@color/text_primary"
            android:textFontWeight="700"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="@+id/wifi_button"
            app:layout_constraintStart_toStartOf="@+id/wifi_button"
            app:layout_constraintTop_toBottomOf="@+id/wifi_button" />

        <!-- Settings Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="40dp"
            android:background="@drawable/gradient_darkblue"
            android:elevation="6dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_settings_white"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="72dp"
            app:iconTint="#ffffff"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/wifi_button"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/settings_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_horizontal"
            android:shadowColor="@color/text_shadow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8"
            android:text="@string/settings"
            android:textColor="@color/text_primary"
            android:textFontWeight="700"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="@+id/settings_button"
            app:layout_constraintStart_toStartOf="@+id/settings_button"
            app:layout_constraintTop_toBottomOf="@+id/settings_button" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/exit_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"
        android:text="@string/exit"
        app:backgroundTint="@color/material_grey_700"
        android:textColor="@android:color/white"
        app:cornerRadius="8dp" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="399dp"
        android:layout_height="44dp"
        android:layout_marginStart="166dp"
        android:layout_marginLeft="166dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="166dp"
        android:layout_marginRight="166dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/main_buttons_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.72"
        app:srcCompat="@drawable/dfsk_logo" />

</androidx.constraintlayout.widget.ConstraintLayout>
