<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- LIVELLO 1: Il tuo gradiente (Sfondo) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.6"
                android:centerY="0.6"
                android:gradientRadius="620"
                android:startColor="#296ddb"
                android:endColor="#030a2a" />
        </shape>
    </item>

    <!-- LIVELLO 2: La tua immagine (Sopra al gradiente) -->
    <!-- Sostituisci "nome_tua_immagine" con il nome del file che hai in res/drawable -->
    <item>
        <bitmap
            android:src="@drawable/bg_all"
            android:gravity="fill" />
    </item>

</layer-list>
